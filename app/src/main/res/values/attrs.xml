<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="SymmetricProgressBar">
        <attr
            name="colors"
            format="reference" />
        <attr
            name="interpolator"
            format="reference" />
        <attr
            name="duration"
            format="reference|integer" />
    </declare-styleable>

    <declare-styleable name="TemplateView">
        <attr name="gnt_template_type" format="reference"/>
    </declare-styleable>



    <declare-styleable name="SubsamplingScaleImageView">
        <attr name="src" format="reference"/>
        <attr name="assetName" format="string"/>
        <attr name="panEnabled" format="boolean"/>
        <attr name="zoomEnabled" format="boolean"/>
        <attr name="quickScaleEnabled" format="boolean"/>
        <attr name="tileBackgroundColor" format="color"/>
    </declare-styleable>






    <declare-styleable name="CropImageView">
        <attr name="cropGuidelines">
            <enum name="off" value="0"/>
            <enum name="onTouch" value="1"/>
            <enum name="on" value="2"/>
        </attr>
        <attr name="cropScaleType">
            <enum name="fitCenter" value="0"/>
            <enum name="center" value="1"/>
            <enum name="centerCrop" value="2"/>
            <enum name="centerInside" value="3"/>
        </attr>
        <attr name="cropShape">
            <enum name="rectangle" value="0"/>
            <enum name="oval" value="1"/>
        </attr>
        <attr name="cropAutoZoomEnabled" format="boolean"/>
        <attr name="cropMaxZoom" format="integer"/>
        <attr name="cropMultiTouchEnabled" format="boolean"/>
        <attr name="cropFixAspectRatio" format="boolean"/>
        <attr name="cropAspectRatioX" format="integer"/>
        <attr name="cropAspectRatioY" format="integer"/>
        <attr name="cropInitialCropWindowPaddingRatio" format="float"/>
        <attr name="cropBorderLineThickness" format="dimension"/>
        <attr name="cropBorderLineColor" format="color"/>
        <attr name="cropBorderCornerThickness" format="dimension"/>
        <attr name="cropBorderCornerOffset" format="dimension"/>
        <attr name="cropBorderCornerLength" format="dimension"/>
        <attr name="cropBorderCornerColor" format="color"/>
        <attr name="cropGuidelinesThickness" format="dimension"/>
        <attr name="cropGuidelinesColor" format="color"/>
        <attr name="cropBackgroundColor" format="color"/>
        <attr name="cropSnapRadius" format="dimension"/>
        <attr name="cropTouchRadius" format="dimension"/>
        <attr name="cropSaveBitmapToInstanceState" format="boolean"/>
        <attr name="cropShowCropOverlay" format="boolean"/>
        <attr name="cropShowProgressBar" format="boolean"/>
        <attr name="cropMinCropWindowWidth" format="dimension"/>
        <attr name="cropMinCropWindowHeight" format="dimension"/>
        <attr name="cropMinCropResultWidthPX" format="float"/>
        <attr name="cropMinCropResultHeightPX" format="float"/>
        <attr name="cropMaxCropResultWidthPX" format="float"/>
        <attr name="cropMaxCropResultHeightPX" format="float"/>
        <attr name="cropFlipHorizontally" format="boolean"/>
        <attr name="cropFlipVertically" format="boolean"/>
    </declare-styleable>


    <attr name="corner_radius" format="dimension" />
    <attr name="borderColor" format="color" />
    <attr name="shadowColor" format="color" />
    <attr name="gradientType" format="integer" />

    <declare-styleable name="AppTextView">
        <attr name="textStyle" />
    </declare-styleable>

    <attr name="textStyle" format="integer">
        <enum name="bold" value="1" />
        <enum name="bold_italic" value="3" />
        <enum name="italic" value="2" />
        <enum name="normal" value="0" />
    </attr>
    <declare-styleable name="gradientTextView">
        <attr name="gradientType" />
        <attr name="startColor" />
        <attr name="endColor" />

    </declare-styleable>

    <declare-styleable name="RoundCornerLayout">
        <attr name="stroke_color" format="reference|color" />
        <attr name="round_as_circle" format="boolean" />
        <attr name="corner_radius" />
        <attr name="stroke_width" format="integer|dimension" />

        <attr name="corner_radius_bottom" format="integer|dimension" />
        <attr name="corner_radius_bottom_left" format="integer|dimension" />
        <attr name="corner_radius_bottom_right" format="integer|dimension" />
        <attr name="corner_radius_top" format="integer|dimension" />
        <attr name="corner_radius_top_left" format="integer|dimension" />
        <attr name="corner_radius_top_right" format="integer|dimension" />
        <attr name="rounded_content_layout" format="reference" />
    </declare-styleable>


    <declare-styleable name="appButtonView">
        <attr name="startColor" format="color" />

        <attr name="adjustDrawableLeft" format="boolean" />
        <attr name="borderColor" />
        <attr name="cornerRadius" />
        <attr name="enableShadow" format="boolean" />
        <attr name="endColor" format="color" />
        <attr name="gradientType" />
        <attr name="icon" format="reference" />
        <attr name="roundedCorner" format="boolean" />
        <attr name="textEndColor" format="color" />
        <attr name="textStartColor" format="color" />
        <attr name="textStyle" />
        <attr name="shadowColor" />
    </declare-styleable>

    <declare-styleable name="appCardView">

        <attr name="startColor" />
        <attr name="endColor" />
        <attr name="gradientType" />
        <attr name="shadowRadius" format="reference|string|integer|boolean|color|float|dimension|fraction" />
        <attr name="cornerRadius" />
        <attr name="borderColor" />
        <attr name="shadowColor" />

    </declare-styleable>
    <declare-styleable name="ProgressWheel">
        <attr name="fillRadius" format="boolean" />
        <attr name="pBarColor" format="color" />
        <attr name="rimColor" format="color" />
        <attr name="rimWidth" format="dimension" />
        <attr name="barSpinCycleTime" format="integer" />
        <attr name="barWidth" format="dimension" />
        <attr name="spinSpeed" format="float" />
        <attr name="progressIndeterminate" format="boolean" />
        <attr name="circleRadius" format="dimension" />

    </declare-styleable>
    <declare-styleable name="RoundedCornerImageView">
        <attr name="left_bottom_corner_radius" format="dimension" />
        <attr name="left_top_corner_radius" format="dimension" />
        <attr name="corner_radius" />
        <attr name="oval" format="boolean" />
        <attr name="border_color" format="color" />
        <attr name="right_bottom_corner_radius" format="dimension" />
        <attr name="right_top_corner_radius" format="dimension" />
        <attr name="border_width" format="dimension" />
    </declare-styleable>
    <declare-styleable name="ShimmerLayout">

        <attr name="shimmer_angle" format="reference|integer">
        </attr>
        <attr name="shimmer_animation_duration" format="reference|integer">
        </attr>
        <attr name="shimmer_auto_start" format="reference|boolean">
        </attr>
        <attr name="shimmer_color" format="reference|color">
        </attr>
        <attr name="shimmer_gradient_center_color_width" format="reference|float">
        </attr>
        <attr name="shimmer_mask_width" format="reference|float">
        </attr>
        <attr name="shimmer_reverse_animation" format="reference|boolean">
        </attr>
    </declare-styleable>
    <declare-styleable name="RoundImageView" />

    <attr name="radiusImage" format="dimension">
    </attr>
</resources>